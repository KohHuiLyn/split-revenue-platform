# Split Revenue Platform - Environment Configuration

# Server
PORT=3000
NODE_ENV=development

# Database
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DB_HOST=localhost
DB_PORT=5432
DB_NAME=your-database-name
DB_USER=postgres
DB_PASSWORD=your-database-password

# Aptos Configuration
APTOS_NODE_URL=https://testnet.api.aptos.dev/v1
APTOS_MODULE_ADDRESS=0x...  # Replace with your deployed module address
APTOS_ADMIN_PRIVATE_KEY=  # Private key in hex format (without 0x prefix)

# Wallet Encryption
WALLET_ENCRYPTION_KEY=your-secure-encryption-key-min-32-chars

# Authentication
JWT_SECRET=your-jwt-secret-key
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=
OAUTH_REDIRECT_URL=http://localhost:3000/auth/callback

# Stripe (for fiat payment processing)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=

# Platform Configuration
PLATFORM_FEE_PERCENTAGE=3  # 3% platform fee
PAYOUT_BATCH_INTERVAL_HOURS=24  # Batch payouts daily
MIN_PAYOUT_AMOUNT_USDC_MICRO=1000000  # $1 minimum

# Logging
LOG_LEVEL=info
