# Splitr Backend - Environment Configuration

# Server (Railway auto-injects PORT)
PORT=3000
NODE_ENV=development

# Database (Railway auto-injects DATABASE_URL when PostgreSQL plugin is added)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE

# Authentication
JWT_SECRET=your-jwt-secret-min-32-chars

# Wallet Encryption (must be at least 32 characters)
WALLET_ENCRYPTION_KEY=your-secure-encryption-key-min-32-chars

# Aptos Blockchain
APTOS_NODE_URL=https://fullnode.testnet.aptoslabs.com/v1
APTOS_MODULE_ADDRESS=0x...
APTOS_ADMIN_PRIVATE_KEY=

# Stripe (for fiat payment processing)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Platform Configuration
PLATFORM_FEE_PERCENTAGE=3
PAYOUT_BATCH_INTERVAL_HOURS=24
MIN_PAYOUT_AMOUNT_USDC_MICRO=1000000

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
